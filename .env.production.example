# ─────────────────────────────────────────────────────────────────────────────
#  .env.production.example
#  Copy this file to .env on the VPS and fill in real values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Backend ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production
GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET=generate_with:_openssl_rand_-base64_32
AUTH_SECRET=generate_with:_openssl_rand_-base64_32
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Admin Credentials ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_to_a_secure_password_12345!

# ─── Frontend ────────────────────────────────────────────────────────────────
# IMPORTANT: Use /api (relative) so that the browser always routes through Nginx.
# Do NOT use a raw IP or port here – that would bypass Nginx and expose the backend.
NEXT_PUBLIC_API_BASE=/api

# ─── Ollama (LLM) ────────────────────────────────────────────────────────────
# Ollama runs as the 'ollama' Docker service on the same internal bridge network.
# Do NOT change OLLAMA_BASE_URL unless you run Ollama on a separate machine.
OLLAMA_BASE_URL=http://ollama:11434
# Model to auto-pull on first deploy. See: https://ollama.com/library
# Examples: llama3.2 | mistral | phi3 | gemma2 | qwen2.5
OLLAMA_MODEL=llama3.2

# ─── Optional ────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# MAX_UPLOAD_SIZE_MB=100
