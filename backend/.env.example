GROQ_API_KEY=your_groq_api_key_here

# Required for login sessions (use a long random string)
AUTH_SECRET=change-this-to-a-long-random-secret

# First admin account — created automatically on first backend start
ADMIN_EMAIL=chat@pership.com
ADMIN_PASSWORD=change-this-admin-password

# Neon PostgreSQL — user data storage (get from Neon console)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
